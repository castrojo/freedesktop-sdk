kind: pyproject

build-depends:
- public-stacks/buildsystem-python-setuptools.bst
- components/grep.bst
- components/findutils.bst
- components/cython.bst

depends:
- components/python3.bst

config:
  build-commands:
    (<):
    - grep -rl '/\* Generated by Cython' | xargs -r rm -v
    - |
      # root directory must follow module-name
      mkdir -p ruamel.yaml.clib
      mv *.pyx ruamel.yaml.clib
      cythonize -3 ruamel.yaml.clib/*.pyx
      mv ruamel.yaml.clib/* .
      rmdir ruamel.yaml.clib

sources:
- kind: git_repo
  url: github:ruamel/yaml.clib.git
  track: '*.*.*'
  ref: 0.2.14-0-g1fb527c36978592aca8e59399f8b5c55421f4677
