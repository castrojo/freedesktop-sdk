kind: manual

build-depends:
- components/binutils.bst
- components/gcc.bst
- components/ostree.bst
- components/pkg-config.bst
- components/rust.bst
- components/stripper.bst

depends:
- public-stacks/runtime-minimal.bst
- components/glib.bst

config:
  build-commands:
  - cargo build --offline --release --bin flat-manager-client

  install-commands:
  - |
    install -Dm755 -t "%{install-root}%{bindir}" target/release/flat-manager-client

  - |
    %{install-extra}

public:
  cpe:
    product: flat-manager

sources:
- kind: git_repo
  url: github:flatpak/flat-manager.git
  track: '*.*.*'
  exclude:
  - "*rc*"
  ref: 0.5.0-0-gb64174ae86c4c78d56d66be3cd58ab3fa5f00ba3
