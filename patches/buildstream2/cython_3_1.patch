From 6ae02ba841cbc453f0856f31ea6d518399799b15 Mon Sep 17 00:00:00 2001
From: Tristan van Berkom <tristan.vanberkom@codethink.co.uk>
Date: Wed, 21 May 2025 18:28:22 +0900
Subject: [PATCH] node.pyx: Fix raise error expression

This oddly suddenly started causing my compiler to crash locally
today, and the raise statement does appear dubious, and the string
formatting has too many arguments, bool.__name__ appears to trigger
the compiler crash.
---
 src/buildstream/node.pyx | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/buildstream/node.pyx b/src/buildstream/node.pyx
index 41599b0e8..2fc417c81 100644
--- a/src/buildstream/node.pyx
+++ b/src/buildstream/node.pyx
@@ -329,8 +329,8 @@ cdef class ScalarNode(Node):
         else:
             provenance = self.get_provenance()
             path = provenance._toplevel._find(self)[-1]
-            raise LoadError("{}: Value of '{}' is not of the expected type '{}'"
-                            .format(provenance, path, bool.__name__, self.value),
+            raise LoadError("{}: Value of '{}' is not of the expected type 'boolean'"
+                            .format(provenance, path),
                             LoadErrorReason.INVALID_DATA)
 
     cpdef object as_enum(self, object constraint):
