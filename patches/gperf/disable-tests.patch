diff --git a/configure.ac b/configure.ac
index 98fe176..634f92e 100644
--- a/configure.ac
+++ b/configure.ac
@@ -30,7 +30,7 @@ AC_EXEEXT
 
 AC_CONFIG_FILES([Makefile])
 
-AC_CONFIG_SUBDIRS([lib src tests doc])
