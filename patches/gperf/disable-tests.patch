 dnl This piece of sed script replaces every line containing '@subdir@'
 dnl by several consecutive lines, each referencing one subdir.
@@ -44,9 +44,6 @@ g
 s/@subdir@/src/
 p
 g
-s/@subdir@/tests/
-p
-g
 s/@subdir@/doc/
 p
 d
