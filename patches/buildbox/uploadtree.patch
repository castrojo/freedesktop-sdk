 4 files changed, 98 insertions(+)

diff --git a/casd/buildboxcasd_localcasinstance.cpp b/casd/buildboxcasd_localcasinstance.cpp
index 9742d6afa..223f258c5 100644
--- a/casd/buildboxcasd_localcasinstance.cpp
+++ b/casd/buildboxcasd_localcasinstance.cpp
@@ -1018,3 +1018,16 @@ Status LocalCasInstance::FetchTree(const FetchTreeRequest &request,
             "The tree is not available in the local CAS or incomplete.");
     }
 }
+
+Status LocalCasInstance::UploadTree(const UploadTreeRequest &request,
+                                    UploadTreeResponse *)
+{
+    if (treeIsAvailableLocally(request.root_digest(), true)) {
+        return grpc::Status::OK;
+    }
+    else {
+        return grpc::Status(
+            grpc::StatusCode::NOT_FOUND,
+            "The tree is not available in the local CAS or incomplete.");
+    }
+}
