From 6cdb62a0b2ccf6ed0cfd4e8a77f46bedd4e12386 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Jonas=20=C3=85dahl?= <jadahl@gmail.com>
Date: Tue, 1 Apr 2025 23:46:51 +0200
Subject: [PATCH] Don't commit frame when with no content set

We'd otherwise end up with a content size of 0x0, which would crash
the cairo plugin due to mmap() with size 0 failing.
---
 src/libdecor.c | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/src/libdecor.c b/src/libdecor.c
index 8cef572..ef6de91 100644
--- a/src/libdecor.c
+++ b/src/libdecor.c
@@ -725,6 +725,10 @@ libdecor_frame_set_visibility(struct libdecor_frame *frame,
 						     : ZXDG_TOPLEVEL_DECORATION_V1_MODE_CLIENT_SIDE);
 	}
 
+	if (frame_priv->content_width <= 0 ||
+	    frame_priv->content_height <= 0)
+		return;
+
 	/* enable/disable decorations that are managed by a plugin */
 	if (frame_has_visible_client_side_decoration(frame)) {
 		/* show client-side decorations */
-- 
