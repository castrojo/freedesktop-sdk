diff --git a/intel/meson.build b/intel/meson.build
index 4af2a357..ad853bb5 100644
--- a/intel/meson.build
+++ b/intel/meson.build
@@ -28,8 +28,7 @@ libdrm_intel = library(
     config_file,
   ],
   include_directories : [inc_root, inc_drm],
-  link_with : libdrm,
-  dependencies : [dep_pciaccess, dep_threads, dep_rt, dep_valgrind, dep_atomic_ops],
+  dependencies : [dep_pciaccess, dep_threads, dep_rt, dep_valgrind, dep_atomic_ops, ext_libdrm],
   c_args : libdrm_c_args,
   gnu_symbol_visibility : 'hidden',
   version : '1.0.0',
@@ -37,7 +36,8 @@ libdrm_intel = library(
 )
 
 ext_libdrm_intel = declare_dependency(
-  link_with : [libdrm, libdrm_intel],
+  link_with : [libdrm_intel],
+  dependencies : [ext_libdrm],
   include_directories : [inc_drm, include_directories('.')],
 )
 
@@ -62,7 +62,8 @@ test_decode = executable(
   'test_decode',
   files('test_decode.c'),
   include_directories : [inc_root, inc_drm],
-  link_with : [libdrm, libdrm_intel],
+  link_with : [libdrm_intel],
+  dependencies : [ext_libdrm],
   c_args : libdrm_c_args,
   gnu_symbol_visibility : 'hidden',
 )
diff --git a/meson.build b/meson.build
index 05f05fd9..07bf71f5 100644
--- a/meson.build
+++ b/meson.build
@@ -189,6 +189,12 @@ if not _vc4.disabled()
 endif
 summary('VC4', with_vc4)
 
+with_libdrm = true
+_libdrm = get_option('libdrm')
+if _libdrm == 'false'
+  with_libdrm = false
+endif
+
 # Among others FreeBSD does not have a separate dl library.
 if not cc.has_function('dlsym')
   dep_dl = cc.find_library('dl', required : with_nouveau)
@@ -297,6 +303,7 @@ else
   libdrm_kw = {'version' : '2.4.0'}
 endif
 
+if with_libdrm
 libdrm = library(
   'drm',
   libdrm_files,
@@ -327,6 +334,10 @@ if meson.version().version_compare('>= 0.54.0')
   meson.override_dependency('libdrm', ext_libdrm)
 endif
 
+else
+ext_libdrm = dependency('libdrm')
+endif
+
 install_headers('libsync.h', 'xf86drm.h', 'xf86drmMode.h')
 install_headers(
   'include/drm/drm.h', 'include/drm/drm_fourcc.h', 'include/drm/drm_mode.h',
@@ -344,12 +355,14 @@ if with_vmwgfx
   install_headers('include/drm/vmwgfx_drm.h', subdir : 'libdrm')
 endif
 
+if get_option('libdrm') != 'false'
 pkg.generate(
   libdrm,
   name : 'libdrm',
   subdirs : ['.', 'libdrm'],
   description : 'Userspace interface to kernel DRM services',
 )
+endif
 
 if with_intel
   subdir('intel')
diff --git a/meson_options.txt b/meson_options.txt
index e80d79e2..b6a85c04 100644
--- a/meson_options.txt
+++ b/meson_options.txt
@@ -18,6 +18,14 @@
 # OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE
 # SOFTWARE.
 
+option(
+  'libdrm',
+  type : 'combo',
+  value : 'true',
+  choices : ['true', 'false'],
+  description : 'Build libdrm library.',
+)
+
 option(
   'intel',
   type : 'feature',
