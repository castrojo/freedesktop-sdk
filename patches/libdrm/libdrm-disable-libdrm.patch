   include_directories : [inc_root, inc_drm],
-  dependencies : [dep_valgrind, dep_threads, dep_rt, dep_atomic_ops],
-  link_with : libdrm,
+  dependencies : [dep_valgrind, dep_threads, dep_rt, dep_atomic_ops, ext_libdrm],
   version : '1.0.0',
   install : true,
