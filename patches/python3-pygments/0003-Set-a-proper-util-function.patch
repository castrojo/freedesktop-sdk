+def test_html_escape():
+    assert util.html_escape('test') == 'test'
+    assert util.html_escape('<>&"\'') == '&lt;&gt;&amp;&quot;&#x27;'
+    assert util.html_escape('<>&"\'', quote=False) == '&lt;&gt;&amp;"\''
+    assert util.html_escape(None) == ''
