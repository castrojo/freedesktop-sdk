 lib/auth/rsa.c     |   2 +-
 lib/auth/rsa_psk.c | 133 +++++++++++++++++++--------------------------
 lib/gnutls_int.h   |   4 --
 lib/priority.c     |   1 -
 4 files changed, 56 insertions(+), 84 deletions(-)

diff --git a/lib/auth/rsa.c b/lib/auth/rsa.c
