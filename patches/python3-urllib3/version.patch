From 5cc9834de4f47bb5bafb03fa12588e314a17c14c Mon Sep 17 00:00:00 2001
From: bbhtt <bbhtt.zn0i8@slmail.me>
Date: Sat, 9 May 2026 05:27:11 +0530
Subject: [PATCH 1/2] Set only-version version scheme

This is needed by requests as it prints a bunch of warnings when the
version has dev or other suffixes. urllib3 adds the suffix by default
when builing from git tag
---
 pyproject.toml | 1 +
 1 file changed, 1 insertion(+)

diff --git a/pyproject.toml b/pyproject.toml
index f084e9c1..4d1f0895 100644
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -131,6 +131,7 @@ docs = [
 [tool.hatch.version]
 source = "vcs"
 [tool.hatch.version.raw-options]
+version_scheme = "only-version"
 local_scheme = "no-local-version"
 [tool.hatch.build.hooks.vcs]
 version-file = "src/urllib3/_version.py"
-- 
