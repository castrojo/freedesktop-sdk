From: Vinay Sajip <vinay_sajip@yahoo.co.uk>
Date: Thu, 4 Jun 2026 10:19:39 +0100
Subject: [PATCH] Remove upper bound for setuptools in build configuration.

---
 pyproject.toml | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/pyproject.toml b/pyproject.toml
index 9964f2e..ac8989b 100644
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -1,6 +1,6 @@
 [build-system]
 requires = [
-    "setuptools >= 68,<75",
+    "setuptools >= 68",
     "wheel"
 ]
 build-backend = 'setuptools.build_meta'
