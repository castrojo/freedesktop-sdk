<?xml version="1.0" encoding="UTF-8"?>
<component type="console-application">
  <id>org.freedesktop.Platform.ClInfo</id>
  <name>Clinfo</name>
  <summary>Print all known information about all available OpenCL platforms and devices in the system</summary>
  <developer id="io.freedesktop_sdk">
    <name>Freedesktop SDK</name>
  </developer>
  <description>
    <p>
    Clinfo is a simple command-line application that enumerates all
    possible (known) properties of the OpenCL platform and devices 
    available on the system.
    </p>
  </description>
  <provides>
    <binary>clinfo</binary>
  </provides>
