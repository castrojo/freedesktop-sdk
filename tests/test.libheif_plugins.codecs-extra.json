{
  "app-id": "test.libheif_plugins.codecs-extra",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "25.08beta",
  "sdk": "org.freedesktop.Sdk",
  "add-extensions": {
    "org.freedesktop.Platform.codecs-extra": {
      "directory": "lib/ffmpeg",
      "version": "25.08beta",
      "add-ld-path": "."
    }
  },
  "command": "test",
  "modules": [
    {
      "name": "test",
      "buildsystem": "simple",
      "build-commands": [
        "g++ -o libheif-plugin libheif_plugin.cc -lheif",
        "mkdir -p /app/lib/ffmpeg",
        "install -Dm0755 libheif-plugin /app/bin/libheif-plugin",
        "install -Dm0755 test /app/bin/test"
      ],
      "sources": [
        {
          "type": "file",
          "path": "libheif_plugin.cc"
        },
        {
          "type": "script",
          "commands": ["exec libheif-plugin /app/lib/ffmpeg/libheif"],
          "dest-filename": "test"
        }
      ]
    }
  ]
}

